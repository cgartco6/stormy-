# Upgrade CLI for nav mode
cat << 'EOL' > stormy/cli/main.py
import sys
from stormy.core import AIEngine, Memory, NavigationEngine
from stormy.voice import listen, speak
from stormy.core.personality import load_personality

def main():
    engine = AIEngine()
    mem = Memory()
    p = load_personality()

    nav_engine = None
    if "--nav" in sys.argv or "--nav-mode" in sys.argv:
        nav_engine = NavigationEngine(speak, p)
        dest = " ".join([arg for arg in sys.argv if arg not in ["--voice", "--nav", "--nav-mode"]]) or "Cape Town Waterfront"
        # In real: geocode dest to (lat,lon) via Nominatim
        nav_engine.set_destination((-33.906, 18.420))  # example Waterfront
        threading.Thread(target=nav_engine.monitor, daemon=True).start()

    print("Stormy online 🔥 (Cape Town vibe) — talk or drive")
    while True:
        user_input = listen() if "--voice" in sys.argv else input("You: ")
        if user_input.lower() in ["exit","bye","quit"]: break
        if "navigate to" in user_input.lower():
            dest = user_input.split("to")[-1].strip()
            print(f"Nav to: {dest}")
            # Trigger nav_engine.set_destination(...)
            speak(f"Got it, heading to {dest}. Try not to get us lost, big guy.")
            continue

        reply = engine.get_response(user_input, mem.get_history())
        print("Stormy:", reply)
        speak(reply)
        mem.add("user", user_input)
        mem.add("assistant", reply)

if __name__ == "__main__":
    main()
EOL

