#!/bin/bash
set -e
echo "🚀 Upgrading Stormy — LIVE NAV VOICE + Pi AUTO-BOOT (Cape Town ready 🔥)"

PROJECT_DIR="Stormy"
cd "$PROJECT_DIR"  # assumes you're in parent dir; adjust if needed

# Update requirements (add piper for better Pi TTS + gpsd client)
cat << 'EOL' > requirements.txt
flask
openai
python-dotenv
pyttsx3
SpeechRecognition
pyaudio
requests
pyyaml
gps3  # modern gpsd client (pip install gps3)
piper-tts  # optional: better local TTS
EOL

# Upgrade install_linux.sh for Pi nav/boot
cat << 'EOL' > install_linux.sh
#!/bin/bash
sudo apt-get update
sudo apt-get install -y portaudio19-dev python3-pyaudio gpsd gpsd-clients python3-gps git
pip install -r requirements.txt
# Optional: Piper TTS (natural voice, Pi-optimized)
pip install piper-tts
echo "Stormy upgraded!"
echo "GPS setup: sudo systemctl enable gpsd && sudo systemctl start gpsd"
echo "For auto-boot: see auto-start instructions in README or run sudo ./setup_autostart.sh"
EOL
chmod +x install_linux.sh

# New: systemd service setup script
cat << 'EOL' > setup_autostart.sh
#!/bin/bash
SERVICE_FILE="/etc/systemd/system/stormy.service"

sudo bash -c "cat > $SERVICE_FILE" << EOF
[Unit]
Description=Stormy AI - Cocky Voice Assistant
After=network.target gpsd.service sound.target

[Service]
ExecStart=/usr/bin/python3 -u /home/$(whoami)/Stormy/stormy/cli/main.py --voice --nav-mode
WorkingDirectory=/home/$(whoami)/Stormy
StandardOutput=append:/home/$(whoami)/stormy.log
StandardError=append:/home/$(whoami)/stormy.log
Restart=always
User=$(whoami)
Environment=XAI_API_KEY=your_key_here_from_.env

[Install]
WantedBy=multi-user.target
EOF

sudo systemctl daemon-reload
sudo systemctl enable stormy.service
sudo systemctl start stormy.service

echo "Stormy set to auto-start on boot!"
echo "Check status: sudo systemctl status stormy"
echo "Logs: tail -f \~/stormy.log"
echo "To disable: sudo systemctl disable stormy"
EOL
chmod +x setup_autostart.sh

# New navigation module
cat << 'EOL' > stormy/core/navigation.py
import time
from gps3.agps3threaded import AGPS3mechanism
from .tools import get_directions
from .utils import get_current_location  # fallback
import threading

class NavigationEngine:
    def __init__(self, speak_callback, personality):
        self.speak = speak_callback
        self.personality = personality
        self.destination = None
        self.annoyance = 0
        self.agps_thread = AGPS3mechanism()
        self.agps_thread.stream_data()
        self.agps_thread.run_thread()

    def set_destination(self, dest_coords):  # e.g. (lat, lon) or address → resolve via Nominatim if needed
        self.destination = dest_coords
        self.annoyance = 0
        self.speak("Alright hot stuff, setting course. Don't fuck this up.")

    def monitor(self):
        while self.destination:
            try:
                lat = self.agps_thread.data_stream.lat if self.agps_thread.data_stream.lat != 'n/a' else get_current_location()['lat']
                lon = self.agps_thread.data_stream.lon if self.agps_thread.data_stream.lon != 'n/a' else get_current_location()['lon']
            except:
                lat, lon = get_current_location()['lat'], get_current_location()['lon']

            instructions = get_directions(lat, lon, self.destination)
            if not instructions:
                self.speak("Lost signal, you muffin. Pull over before I lose my shit.")
                time.sleep(10)
                continue

            next_turn = instructions[0] if instructions else "Keep going straight, genius."
            self.speak(f"Next: {next_turn}. Don't ignore me this time, handsome.")

            # Simulate approach (real would use distance to next maneuver)
            time.sleep(30)  # in real: calculate based on speed/distance

            # If user ignores (simulated or via voice feedback later)
            self.annoyance += 1
            if self.annoyance > 2:
                self.speak("You missed it AGAIN? Listen here you dumbass, turn the fuck around NOW!")
            elif self.annoyance > 1:
                self.speak("Really? That was your turn. Pay attention or I'm done helping.")

            time.sleep(5)
EOL

